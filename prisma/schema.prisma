generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id        String   @id @default(cuid())
  title     String
  author    String
  content   String
  icon      String   @default("file-text")
  createdAt DateTime @default(now())
}
